nemaHoleSketch = sketch(on = offsetPlane(XY, offset = tubeLength - 1mm)) {
  nemaHoleFrontRight = circle(start = [var 22.7mm, var 21mm], center = [var 21mm, var 21mm])
  nemaHoleFrontLeft = circle(start = [var -19.3mm, var 21mm], center = [var -21mm, var 21mm])
  nemaHoleBackLeft = circle(start = [var -19.3mm, var -21mm], center = [var -21mm, var -21mm])
  nemaHoleBackRight = circle(start = [var 22.7mm, var -21mm], center = [var 21mm, var -21mm])

  horizontal([
    nemaHoleFrontRight.center,
    nemaHoleFrontRight.start
  ])
  horizontal([
    nemaHoleFrontLeft.center,
    nemaHoleFrontLeft.start
  ])
  horizontal([
    nemaHoleBackLeft.center,
    nemaHoleBackLeft.start
  ])
  horizontal([
    nemaHoleBackRight.center,
    nemaHoleBackRight.start
  ])

  horizontalDistance([ORIGIN, nemaHoleFrontRight.center]) == m3PatternPitch / 2
  verticalDistance([ORIGIN, nemaHoleFrontRight.center]) == m3PatternPitch / 2
  horizontalDistance([ORIGIN, nemaHoleFrontLeft.center]) == -m3PatternPitch / 2
  verticalDistance([ORIGIN, nemaHoleFrontLeft.center]) == m3PatternPitch / 2
  horizontalDistance([ORIGIN, nemaHoleBackLeft.center]) == -m3PatternPitch / 2
  verticalDistance([ORIGIN, nemaHoleBackLeft.center]) == -m3PatternPitch / 2
  horizontalDistance([ORIGIN, nemaHoleBackRight.center]) == m3PatternPitch / 2
  verticalDistance([ORIGIN, nemaHoleBackRight.center]) == -m3PatternPitch / 2

  diameter(nemaHoleFrontRight) == m3ClearanceDiameter
  equalRadius([
    nemaHoleFrontRight,
    nemaHoleFrontLeft,
    nemaHoleBackLeft,
    nemaHoleBackRight
  ])
}
nemaHoleFrontRightRegion = region(point = [21mm, 21mm], sketch = nemaHoleSketch)
nemaHoleFrontLeftRegion = region(point = [-21mm, 21mm], sketch = nemaHoleSketch)
nemaHoleBackLeftRegion = region(point = [-21mm, -21mm], sketch = nemaHoleSketch)
nemaHoleBackRightRegion = region(point = [21mm, -21mm], sketch = nemaHoleSketch)
nemaHoleCutters = extrude(
  [
    nemaHoleFrontRightRegion,
    nemaHoleFrontLeftRegion,
    nemaHoleBackLeftRegion,
    nemaHoleBackRightRegion
  ],
  length = flangeThickness + 2mm,
  method = NEW,
)
hide(nemaHoleSketch)

