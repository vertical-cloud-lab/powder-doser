  horizontalDistance([ORIGIN, piHoleBottomRight.center]) == piMountWidth / 2
  verticalDistance([ORIGIN, piHoleBottomRight.center]) == piBossCenterZ - (piMountHeight / 2)

  diameter(piHoleTopRight) == m25ClearanceDiameter
  equalRadius([
    piHoleTopRight,
    piHoleTopLeft,
    piHoleBottomLeft,
    piHoleBottomRight
  ])
}
piHoleTopRightRegion = region(point = [29mm, 67.5mm], sketch = piHoleSketch)
piHoleTopLeftRegion = region(point = [-29mm, 67.5mm], sketch = piHoleSketch)
piHoleBottomLeftRegion = region(point = [-29mm, 44.5mm], sketch = piHoleSketch)
piHoleBottomRightRegion = region(point = [29mm, 44.5mm], sketch = piHoleSketch)
piHoleCutters = extrude(
  [
    piHoleTopRightRegion,
    piHoleTopLeftRegion,
    piHoleBottomLeftRegion,
    piHoleBottomRightRegion
  ],
  length = 10mm,
  method = NEW,
)
hide(piHoleSketch)

housingWithBore = subtract(housingBlank, tools = boreCutter)
housingWithExitHole = subtract(housingWithBore, tools = exitHoleCutter)
housingWithExitChamfer = subtract(housingWithExitHole, tools = exitChamferCutter)
housingWithSideInlet = subtract(housingWithExitChamfer, tools = sideInletCutter)
housingWithVibrationPocket = subtract(housingWithSideInlet, tools = vibrationPocketCutter)
housingWithVibrationWire = subtract(housingWithVibrationPocket, tools = vibrationWireCutter)
housingWithSolenoidWire = subtract(housingWithVibrationWire, tools = solenoidWireCutter)
housingWithSolenoidPocket = subtract(housingWithSolenoidWire, tools = solenoidPocketCutter)
housingWithNemaHoles = subtract(housingWithSolenoidPocket, tools = nemaHoleCutters)
dispenserHousing = subtract(housingWithNemaHoles, tools = piHoleCutters)
appearance(
  dispenserHousing,
  color = "#d8d2c4",
  roughness = 82,
  metalness = 0,
)

// Auger spindle and 5 mm to 5 mm set-screw coupling reference parts.
spindleSketch = sketch(on = offsetPlane(XY, offset = bottomCapThickness + 0.3mm)) {
  spindleCircle = circle(start = [var 2.5mm, var 0mm], center = [var 0mm, var 0mm])

  coincident([spindleCircle.center, ORIGIN])
  horizontal([
    spindleCircle.center,
    spindleCircle.start
  ])
  diameter(spindleCircle) == 5mm
}
spindleRegion = region(point = [0mm, 0mm], sketch = spindleSketch)
augerSpindle = extrude(spindleRegion, length = tubeLength + 6mm, method = NEW)
  |> appearance(color = "#b6b8bd", roughness = 35, metalness = 70)
hide(spindleSketch)

couplingOuterSketch = sketch(on = offsetPlane(XY, offset = flangeTopZ)) {
  couplingOuterCircle = circle(start = [var 6mm, var 0mm], center = [var 0mm, var 0mm])

  coincident([couplingOuterCircle.center, ORIGIN])
  horizontal([
    couplingOuterCircle.center,
    couplingOuterCircle.start
  ])
  diameter(couplingOuterCircle) == 12mm
}
couplingOuterRegion = region(point = [0mm, 0mm], sketch = couplingOuterSketch)
couplingBlank = extrude(couplingOuterRegion, length = 18mm, method = NEW)
hide(couplingOuterSketch)

couplingBoreSketch = sketch(on = offsetPlane(XY, offset = flangeTopZ - 0.5mm)) {
  couplingBoreCircle = circle(start = [var 2.5mm, var 0mm], center = [var 0mm, var 0mm])

  coincident([couplingBoreCircle.center, ORIGIN])
  horizontal([
    couplingBoreCircle.center,
    couplingBoreCircle.start
  ])
  diameter(couplingBoreCircle) == 5mm
}
couplingBoreRegion = region(point = [0mm, 0mm], sketch = couplingBoreSketch)
couplingBoreCutter = extrude(couplingBoreRegion, length = 19mm, method = NEW)
hide(couplingBoreSketch)

setScrewSketch = sketch(on = offsetPlane(YZ, offset = -6.5mm)) {
  lowerSetScrewHole = circle(start = [var 1.5mm, var 122mm], center = [var 0mm, var 122mm])
  upperSetScrewHole = circle(start = [var 1.5mm, var 129mm], center = [var 0mm, var 129mm])

  horizontal([
    lowerSetScrewHole.center,
    lowerSetScrewHole.start
  ])
  horizontal([
    upperSetScrewHole.center,
    upperSetScrewHole.start
  ])
  horizontalDistance([ORIGIN, lowerSetScrewHole.center]) == 0mm
  verticalDistance([ORIGIN, lowerSetScrewHole.center]) == flangeTopZ + 6mm
  horizontalDistance([ORIGIN, upperSetScrewHole.center]) == 0mm
  verticalDistance([ORIGIN, upperSetScrewHole.center]) == flangeTopZ + 13mm
  diameter(lowerSetScrewHole) == 3mm
  equalRadius([lowerSetScrewHole, upperSetScrewHole])
}
lowerSetScrewRegion = region(point = [0mm, 122mm], sketch = setScrewSketch)
upperSetScrewRegion = region(point = [0mm, 129mm], sketch = setScrewSketch)
setScrewCutters = extrude(
  [
    lowerSetScrewRegion,
    upperSetScrewRegion
  ],
  length = 13mm,
  method = NEW,
)
hide(setScrewSketch)

couplingWithBore = subtract(couplingBlank, tools = couplingBoreCutter)
setScrewCoupling = subtract(couplingWithBore, tools = setScrewCutters)
appearance(
  setScrewCoupling,
  color = "#383838",
  roughness = 45,
  metalness = 55,
)

// SG90 servo and thin deflector blade reference parts.
servoBodySketch = sketch(on = offsetPlane(XY, offset = -34mm)) {
  servoBodyBottom = line(start = [var -11.5mm, var -6mm], end = [var 11.5mm, var -6mm])
  servoBodyRight = line(start = [var 11.5mm, var -6mm], end = [var 11.5mm, var 6mm])
  servoBodyTop = line(start = [var 11.5mm, var 6mm], end = [var -11.5mm, var 6mm])
  servoBodyLeft = line(start = [var -11.5mm, var 6mm], end = [var -11.5mm, var -6mm])

  coincident([
    servoBodyBottom.end,
    servoBodyRight.start
  ])
  coincident([servoBodyRight.end, servoBodyTop.start])
  coincident([servoBodyTop.end, servoBodyLeft.start])
  coincident([
    servoBodyLeft.end,
    servoBodyBottom.start
  ])

  horizontal(servoBodyBottom)
  vertical(servoBodyRight)
  horizontal(servoBodyTop)
  vertical(servoBodyLeft)

  horizontalDistance([ORIGIN, servoBodyBottom.start]) == -servoWidth / 2
  verticalDistance([ORIGIN, servoBodyBottom.start]) == -servoDepth / 2
  horizontalDistance([
  servoBodyBottom.start,
  servoBodyBottom.end
]) == servoWidth
  verticalDistance([
  servoBodyRight.start,
  servoBodyRight.end
]) == servoDepth
}
servoBodyRegion = region(point = [0mm, 0mm], sketch = servoBodySketch)
sg90Servo = extrude(servoBodyRegion, length = servoHeight, method = NEW)
  |> appearance(color = "#1f64c8", roughness = 55, metalness = 5)
hide(servoBodySketch)

servoOutputSketch = sketch(on = offsetPlane(XY, offset = -7.5mm)) {
  servoOutputCircle = circle(start = [var 3mm, var 0mm], center = [var 0mm, var 0mm])

  coincident([servoOutputCircle.center, ORIGIN])
  horizontal([
    servoOutputCircle.center,
    servoOutputCircle.start
  ])
  diameter(servoOutputCircle) == 6mm
}
servoOutputRegion = region(point = [0mm, 0mm], sketch = servoOutputSketch)
servoOutputHub = extrude(servoOutputRegion, length = 4.5mm, method = NEW)
  |> appearance(color = "#f0f2f6", roughness = 35, metalness = 0)
hide(servoOutputSketch)

deflectorBladeSketch = sketch(on = offsetPlane(XY, offset = -4.2mm)) {
  bladeBottom = line(start = [var -10mm, var -6mm], end = [var 10mm, var -6mm])
  bladeRight = line(start = [var 10mm, var -6mm], end = [var 10mm, var 6mm])
  bladeTop = line(start = [var 10mm, var 6mm], end = [var -10mm, var 6mm])
  bladeLeft = line(start = [var -10mm, var 6mm], end = [var -10mm, var -6mm])

  coincident([bladeBottom.end, bladeRight.start])
  coincident([bladeRight.end, bladeTop.start])
  coincident([bladeTop.end, bladeLeft.start])
  coincident([bladeLeft.end, bladeBottom.start])

  horizontal(bladeBottom)
  vertical(bladeRight)
  horizontal(bladeTop)
  vertical(bladeLeft)

  horizontalDistance([ORIGIN, bladeBottom.start]) == -bladeLength / 2
  verticalDistance([ORIGIN, bladeBottom.start]) == -bladeWidth / 2
  horizontalDistance([bladeBottom.start, bladeBottom.end]) == bladeLength
  verticalDistance([bladeRight.start, bladeRight.end]) == bladeWidth
}
deflectorBladeRegion = region(point = [0mm, 0mm], sketch = deflectorBladeSketch)
deflectorBlade = extrude(deflectorBladeRegion, length = bladeThickness, method = NEW)
  |> appearance(color = "#d9a334", roughness = 45, metalness = 35)
hide(deflectorBladeSketch)
