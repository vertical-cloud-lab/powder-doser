  horizontalDistance([ORIGIN, solenoidBossBottom.start]) == -11mm
  verticalDistance([ORIGIN, solenoidBossBottom.start]) == solenoidCenterZ - 11mm
  horizontalDistance([
  solenoidBossBottom.start,
  solenoidBossBottom.end
]) == 22mm
  verticalDistance([
  solenoidBossRight.start,
  solenoidBossRight.end
]) == 22mm
}
