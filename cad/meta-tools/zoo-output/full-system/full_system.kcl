  horizontalDistance([ORIGIN, piBossBottom.start]) == -piBossWidth / 2
  verticalDistance([ORIGIN, piBossBottom.start]) == piBossCenterZ - (piBossHeight / 2)
  horizontalDistance([piBossBottom.start, piBossBottom.end]) == piBossWidth
  verticalDistance([piBossRight.start, piBossRight.end]) == piBossHeight
}
