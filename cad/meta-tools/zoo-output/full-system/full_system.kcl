/*
Generated by Text-to-CAD:
A 3D-printable powder dispenser housing in mm. Vertical hollow tube, 24 outside diameter, 20 inside bore, 110 long. Top: 50x50x6 square flange with four M3 holes on a 42 mm square pattern, for mounting a NEMA 17 stepper (42x42 footprint). The auger spindle (5 mm) couples directly to the stepper shaft via a 5x5 set-screw coupling. Side inlet hopper neck, 12 mm diameter, just below the flange. Near the bottom (within 25 mm of dispense exit): a 12x4 deep circular pocket on +X for a 10 mm ERM vibration disc, and a 16x16x12 deep rectangular pocket on -X for a small solenoid. Each pocket has a 4 mm wire-exit channel. Dispense exit: chamfered 4 mm hole at the bottom. Below the exit, a yoke that holds an SG90 servo (23x12x27) so the servo pivots a 20x12x1.2 deflector blade about the dispense axis. Back face: a 60x30 mounting boss for a Raspberry Pi Zero 2 W with four M2.5 holes on a 58x23 grid.
*/
@settings(defaultLengthUnit = mm, kclVersion = 1.0)

tubeOuterDiameter = 24mm
tubeInnerDiameter = 20mm
tubeLength = 110mm
flangeSide = 50mm
flangeThickness = 6mm
flangeTopZ = tubeLength + flangeThickness
m3ClearanceDiameter = 3.4mm
m3PatternPitch = 42mm
bottomCapThickness = 3.5mm
exitHoleDiameter = 4mm
exitChamferDiameter = 8mm
sideInletCenterZ = 101mm
sideInletBoreDiameter = 12mm
sideInletOuterDiameter = 16mm
vibrationCenterZ = 18mm
vibrationBossDiameter = 18mm
vibrationPocketDiameter = 12mm
solenoidCenterZ = 18mm
piBossCenterZ = 56mm
piBossWidth = 60mm
piBossHeight = 30mm
piMountWidth = 58mm
piMountHeight = 23mm
m25ClearanceDiameter = 2.8mm
servoWidth = 23mm
servoDepth = 12mm
servoHeight = 27mm
bladeLength = 20mm
bladeWidth = 12mm
bladeThickness = 1.2mm

// Main printable housing blank.
tubeOuterSketch = sketch(on = XY) {
  tubeOuterCircle = circle(start = [var 12mm, var 0mm], center = [var 0mm, var 0mm])

  coincident([tubeOuterCircle.center, ORIGIN])
  horizontal([
    tubeOuterCircle.center,
    tubeOuterCircle.start
  ])
  diameter(tubeOuterCircle) == tubeOuterDiameter
}
tubeOuterRegion = region(point = [0mm, 0mm], sketch = tubeOuterSketch)
tubeBlank = extrude(tubeOuterRegion, length = tubeLength, method = NEW)
hide(tubeOuterSketch)

flangeSketch = sketch(on = offsetPlane(XY, offset = tubeLength)) {
  flangeBottomEdge = line(start = [var -25mm, var -25mm], end = [var 25mm, var -25mm])
  flangeRightEdge = line(start = [var 25mm, var -25mm], end = [var 25mm, var 25mm])
  flangeTopEdge = line(start = [var 25mm, var 25mm], end = [var -25mm, var 25mm])
  flangeLeftEdge = line(start = [var -25mm, var 25mm], end = [var -25mm, var -25mm])

  coincident([
    flangeBottomEdge.end,
    flangeRightEdge.start
  ])
  coincident([
    flangeRightEdge.end,
    flangeTopEdge.start
  ])
  coincident([
    flangeTopEdge.end,
    flangeLeftEdge.start
  ])
  coincident([
    flangeLeftEdge.end,
    flangeBottomEdge.start
  ])

  horizontal(flangeBottomEdge)
  vertical(flangeRightEdge)
  horizontal(flangeTopEdge)
  vertical(flangeLeftEdge)

  horizontalDistance([ORIGIN, flangeBottomEdge.start]) == -flangeSide / 2
  verticalDistance([ORIGIN, flangeBottomEdge.start]) == -flangeSide / 2
  horizontalDistance([
  flangeBottomEdge.start,
  flangeBottomEdge.end
]) == flangeSide
  verticalDistance([
  flangeRightEdge.start,
  flangeRightEdge.end
]) == flangeSide
}
flangeRegion = region(point = [0mm, 0mm], sketch = flangeSketch)
flangeBlank = extrude(flangeRegion, length = flangeThickness, method = NEW)
hide(flangeSketch)

sideNeckOuterSketch = sketch(on = offsetPlane(XZ, offset = 8mm)) {
  sideNeckOuterCircle = circle(start = [var 8mm, var 101mm], center = [var 0mm, var 101mm])

  horizontal([
    sideNeckOuterCircle.center,
    sideNeckOuterCircle.start
  ])
  horizontalDistance([ORIGIN, sideNeckOuterCircle.center]) == 0mm
  verticalDistance([ORIGIN, sideNeckOuterCircle.center]) == sideInletCenterZ
  diameter(sideNeckOuterCircle) == sideInletOuterDiameter
}
sideNeckOuterRegion = region(point = [0mm, 101mm], sketch = sideNeckOuterSketch)
sideNeckBlank = extrude(sideNeckOuterRegion, length = 30mm, method = NEW)
hide(sideNeckOuterSketch)

