  piBossBottom = line(start = [var -30mm, var 41mm], end = [var 30mm, var 41mm])
  piBossRight = line(start = [var 30mm, var 41mm], end = [var 30mm, var 71mm])
  piBossTop = line(start = [var 30mm, var 71mm], end = [var -30mm, var 71mm])
  piBossLeft = line(start = [var -30mm, var 71mm], end = [var -30mm, var 41mm])

