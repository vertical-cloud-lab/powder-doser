solenoidBossSketch = sketch(on = offsetPlane(YZ, offset = -9mm)) {
  solenoidBossBottom = line(start = [var -11mm, var 7mm], end = [var 11mm, var 7mm])
  solenoidBossRight = line(start = [var 11mm, var 7mm], end = [var 11mm, var 29mm])
  solenoidBossTop = line(start = [var 11mm, var 29mm], end = [var -11mm, var 29mm])
