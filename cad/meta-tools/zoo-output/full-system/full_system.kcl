housingBlank = union([
  tubeBlank,
  flangeBlank,
  sideNeckBlank,
  vibrationBossBlank,
  solenoidBossBlank,
  piBossBlank,
  yokeRightBlank,
  yokeLeftBlank,
  yokeBackBridgeBlank
])

// True subtractive housing features.
boreSketch = sketch(on = offsetPlane(XY, offset = bottomCapThickness)) {
  boreCircle = circle(start = [var 10mm, var 0mm], center = [var 0mm, var 0mm])

  coincident([boreCircle.center, ORIGIN])
  horizontal([boreCircle.center, boreCircle.start])
  diameter(boreCircle) == tubeInnerDiameter
}
boreRegion = region(point = [0mm, 0mm], sketch = boreSketch)
boreCutter = extrude(boreRegion, length = flangeTopZ - bottomCapThickness + 1mm, method = NEW)
hide(boreSketch)

exitHoleSketch = sketch(on = offsetPlane(XY, offset = -1mm)) {
  exitHoleCircle = circle(start = [var 2mm, var 0mm], center = [var 0mm, var 0mm])

  coincident([exitHoleCircle.center, ORIGIN])
  horizontal([
