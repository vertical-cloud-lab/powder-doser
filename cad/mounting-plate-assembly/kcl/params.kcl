// Shared parameter sheet for the powder-doser mounting-plate assembly.
//
// COORDINATES: auger long axis = +Y. Dispense tip at +Y, motor end at -Y.
// +Z is up; powder falls in -Z. All units mm.
//
// All upstream-part dimensions are kept in lock-step with the source PRs:
//
//   * PR #49 v3 — geared Archimedes auger + 16T stepper pinion + NEMA 11
//     (cad/auger-geared/)
//   * PR #51    — split tap collar + mount plate
//     (design/cad/tap-collar/)
//   * PR #55    — split shaft-collar auger bracket
//     (cad/auger-bracket/)

// ============================ IMPORTED PARTS ============================ //

// ---- Geared Archimedes auger + pinion (PR #49) ----
augerOd                = 25.0
augerLen               = 250.0
gearBandFromDispEnd    = augerLen / 3.0       // 83.33 mm
gearBandFaceW          = 10.0
gearBandTipDia         = 50.0                 // 48T module-1 tip dia
pinionTipDia           = 18.0                 // 16T module-1 tip dia
pinionLen              = 16.0
gearCentreDistance     = 32.0                 // C = (48+16)*1/2

// ---- NEMA 11 stepper (PR #49 BOM item 10 — 11HS18-0674S) ----
nema11BodyW            = 28.2                 // square cross-section
nema11BodyL            = 32.0                 // along motor axis
nema11FaceHolePitch    = 23.0                 // M2.5 corner pitch (using M3 in our boss)
nema11PilotDia         = 22.0                 // central pilot
nema11ShaftDia         = 5.0
nema11ShaftLen         = 18.0

// ---- Auger bracket (PR #47: 60 × 12 × 14 mm flange, 2 × M3 at X = ±24)
//      LIFTED variant: 14 mm-thick flange raises the bore axis to 29.25 mm
//      above the flange bottom, giving the PR #49 Ø50 gear band 4.25 mm of
//      radial clearance over a flat plate (no slot, no plinth required). ----
brkFlangeW             = 60.0                 // along X
brkFlangeD             = 12.0                 // along Y (auger axis)
brkFlangeT             = 14.0                 // Z (lifted)
brkMountHoleInsetX     = 6.0                  // → hole centres at X = ±24
brkMountHoleD          = 3.4                  // M3 clearance
brkCollarOd            = 33.5                 // outside diameter of the collar ring
brkCollarPlateOverlap  = 1.5
brkRingCentreLocalZ    = brkFlangeT + (brkCollarOd / 2.0) - brkCollarPlateOverlap   // 29.25 mm

// ---- Tap-collar mount plate (PR #51 latest: 60 × 18 × 14, 2 × M3 at X = ±24) ----
tapPlateW              = 60.0                 // along X
tapPlateD              = 18.0                 // along Y — matches lengthened TC collar
tapPlateT              = 14.0                 // Z — matches bracket flange thickness
tapMountHoleInsetX     = 6.0
tapMountHoleD          = 3.4

// ============================ HARDWARE =================================== //
m3Clear                = 3.4
m5Clear                = 5.4

// ============================ THIS PACKAGE =============================== //
//
// Layout per the issue #62 third review:
//   * every component (brackets, tap-collar mount, motor block, front
//     ramps, hinge eyes) sits on the TOP surface of the mounting plate
//   * plate is SYMMETRIC about X=0 — auger in the middle, motor mount
//     extends to one side, opposite side is clear
//   * brackets bolt DIRECTLY to the plate top (no plinths)
//   * NO features hang from the plate underside (no actuator lug)
//   * the two side hinges are EQUAL in size, mirror-symmetric about X=0
//   * NO holes or gaps other than mounting holes, a single open
//     U-notch in the +Y edge for the auger overhang, and a minimum
//     gear-band+pinion clearance cutout under the band
//   * two SEPARATE side hinges (one each side of the auger), with the
//     rotation axis 10 mm forward of the baseplate's front edge
//   * Y order from the hinge end to the motor end:
//         hinge → front bracket → tap collar → motor (over gear band) →
//         rear bracket

// Tap-collar bore Z (above the mount-plate bottom).  The PR #51 collar
// bore is at 29.25 mm — exactly the same as the PR #47 bracket bore —
// so bracket + tap-collar + auger gear are at the same Z and bolt flat
// to a flush plate top.
tapCollarBoreLocalZ    = 29.25

// ---- Mounting plate ----
plateT                 = 6.0                  // Z thickness

// Brackets bolt directly to the plate top — auger axis sits at the
// LIFTED bracket's native bore height (29.25 mm) above the plate top,
// so the Ø50 gear band clears the plate top by 4.25 mm — no plinths
// and no through-plate slot.
zAug                   = brkRingCentreLocalZ               // +29.25 mm

// Auger spans Y = [yRear, yDisp]. Dispense end at +Y.
yDisp                  = +augerLen / 2.0                   // +125 mm
yRear                  = -augerLen / 2.0                   // -125 mm
yGearBand              = yDisp - gearBandFromDispEnd       // +41.67 mm

// Component Y positions (hinge end → far end, matching issue #62 drawing).
// Front bracket / tap collar / gear band are packed flush along Y with
// only a 1 mm air-clearance gap so gravity holds them against the
// brackets (per the fifth review).
packGap                = 1.0
yTap                   = yGearBand + (gearBandFaceW / 2.0) + packGap + (tapPlateD / 2.0)   // +56.67
yBrkFront              = yTap + (tapPlateD / 2.0) + packGap + (brkFlangeD / 2.0)           // +72.67
yBrkRear               = -95.0

// SYMMETRIC plate X envelope (auger centred at X=0, plate mirrored).
plateXHalf             = +gearCentreDistance + (nema11BodyW / 2.0) + 8.0   // 54.1
plateXMin              = -plateXHalf
plateXMax              = +plateXHalf
plateW                 = plateXMax - plateXMin
plateXCentre           = 0.0

// Plate Y envelope — plate front edge 10 mm short of the hinge axis.
plateYFront            = yDisp - 10.0                      // +115
plateYBack             = yBrkRear - (brkFlangeD / 2.0) - 7.0     // -114.5
plateL                 = plateYFront - plateYBack
plateYCentre           = (plateYFront + plateYBack) / 2.0

// Auger gap — open U-notch in the +Y plate edge.  The auger overhangs
// in mid-air through this gap; the gap is also what separates the two
// front ramps and the two side hinges.
augerGapW              = 32.0
augerGapYBack          = plateYFront - 35.0                // +80

// NEMA-11 motor mount block — sits ON TOP of plate; its +Y face carries
// the motor face holes; motor body extends in -Y from that face.  The
// motor face is placed so the pinion centre sits exactly on the gear
// band centre in Y — no Y-axis offset (per the fifth review).
xMotor                 = +gearCentreDistance               // +32 mm
zMotor                 = zAug
motorFaceY             = yGearBand - (pinionLen / 2.0) - 2.0   // +31.67
bossW                  = nema11BodyW + 8.0                 // 36.2
bossH                  = nema11BodyW + 8.0                 // 36.2
bossT                  = 6.0

// 3-layer sandwich hinges — each side of the auger gap carries
// {inner mounting-plate lobe, middle baseplate arm, outer mounting-plate
// lobe} sharing a single M5 pin per side (per the fifth review).  Each
// lobe takes one third of the ramp half-span.
hingeEyeOd             = 18.0
hingeEyeId             = m5Clear
hingeLayerGap          = 0.4
rampHalfSpan           = (plateXMax - plateXCentre) - (augerGapW / 2.0)
hingeLobeW             = rampHalfSpan / 3.0
hingeX0                = +augerGapW / 2.0
hingeX1                = hingeX0 + hingeLobeW
hingeX2                = hingeX0 + 2.0 * hingeLobeW
hingeX3                = plateXMax

// Front ramps — each is a right-triangle prism (in YZ) extruded along
// X from the auger-gap edge out to the plate X edge for its side.
// Together the two ramps cover the entire +Y plate face except for the
// auger gap.
rampYBack              = plateYFront - 25.0                // +90
rampTopZ               = zAug + hingeEyeOd / 2.0           // +36.25

// (No linear-actuator rod-end pivot lug — no underside features.)

// ---- Baseplate (sits on the bench) ----
// Per Will's PR #66 review (comment 4615931709) the baseplate is now a
// trapezoidal tabletop on a TRIPOD: two front-corner legs + one
// rear-centre leg, with the tabletop tapering from the full-width
// front edge back to a narrow rear edge.
baseT                  = 6.0
baseLegH               = 95.0
baseLegW               = 18.0
baseLegInset           = 12.0

// Tabletop trapezoid — full width at the front edge (near the hinge),
// tapering to a narrow rear edge centred over the single rear leg.
baseFrontHalfW         = 100.0                             // ±100 at front
baseRearHalfW          = 32.0                              // ±32 at rear

// Baseplate position — front edge 10 mm BEHIND the hinge axis, so the
// hinge axis sits 10 mm in front of the baseplate's front edge.
baseYFront             = yDisp - 10.0                      // +115
// Rear edge pulled forward from -135 to -75 per @swcharles' note (the
// rear leg only has to sit a small distance behind the worst-case
// fully-loaded COM ≈ Y +15); rear foot ends up ≈ Y -54.
baseYRear              = -75.0
baseYBack              = baseYRear                          // back-compat alias
baseYCentre            = (baseYFront + baseYRear) / 2.0
baseW                  = 2.0 * baseFrontHalfW              // front-edge width
baseL                  = baseYFront - baseYRear

// zBaseTop is the BOTTOM of the baseplate body; base top = zBaseTop + baseT.
zBaseTop               = -plateT - 8.0                     // -14

// Baseplate hinge arms — middle layer of the 3-layer sandwich, one each
// side of the auger gap.  Each arm occupies the centre third of its
// ramp half-span between the mounting plate's inner and outer lobes.
// The arm bottom face extends BACK onto the baseplate top for full
// contact with the baseplate (per Will's review).
armThk                 = hingeLobeW - hingeLayerGap
hingeAxisZLocal        = zAug - zBaseTop
armBaseSupportLen      = 40.0

// The arm's BACK (toward -Y, motor) face is sloped from arm_back_y at
// the baseplate top up to a point near the hinge axis level, giving
// the mounting plate's underside clearance to sweep through 45° and
// beyond (per Will's PR #66 review comment on 45° interference).
armSlopeRun            = 16.0                              // ~58° from horizontal

// ============================ HINGE GEAR + SERVO (issue #63) ========== //
//
// A spur gear is added to the +X OUTER mounting-plate hinge lobe so a
// servo on the baseplate can drive the tilt of the mounting plate.  A
// 2:1 reduction between hinge gear and pinion keeps the torque load on
// the MG996R within its 9.4 kgf·cm rating.  Module is back-solved from
// the centre distance so the 40-T hinge gear at Z = zAug meshes with
// the 20-T pinion at the required Z (= 10 mm above the baseplate top,
// the centreline of the MG996R's 20 mm-thick body).
gearHingeTeeth         = 40
gearPinionTeeth        = 20
gearFaceW              = hingeLobeW - hingeLayerGap        // match outer lobe
pinionZAboveBaseTop    = 10.0                              // MG996R body midline
gearCentreC            = zAug - (zBaseTop + baseT + pinionZAboveBaseTop)   // 27.25
gearModule             = (2.0 * gearCentreC) / (gearHingeTeeth + gearPinionTeeth)  // ≈ 0.9083
gearHingePcd           = gearHingeTeeth * gearModule
gearPinionPcd          = gearPinionTeeth * gearModule
gearHingeTipD          = gearHingePcd + 2 * gearModule
gearPinionTipD         = gearPinionPcd + 2 * gearModule
// The hinge gear band replaces the cylindrical eye on the +X outer
// mounting-plate hinge lobe.  X centre is the midpoint of that lobe's
// X span.
gearXCentre            = (hingeX2 + hingeLayerGap / 2 + hingeX3) / 2.0
gearXLo                = gearXCentre - gearFaceW / 2.0
gearXHi                = gearXCentre + gearFaceW / 2.0

// ---- MG996R servo (per the dimensioned drawing on PR #66) ----
mg996rBodyL            = 40.0     // along spline-perpendicular long axis (Y)
mg996rBodyT            = 20.0     // body thickness (Z)
mg996rBodyH            = 36.8     // body height (X — inward from flange face)
mg996rFlangeL          = 54.5     // flange total length along Y
mg996rFlangeT          = 2.0      // flange ear thickness along X
mg996rHoleDia          = 5.0      // Ø5 mounting holes
mg996rHoleYSpread      = 49.5     // hole pair spread along body length (Y)
mg996rHoleZSpread      = 10.0     // hole pair spread along body thickness (Z)
mg996rSplineYOffset    = 10.1     // spline offset from near body-end along Y

// ---- Servo mount — TWO SQUARE posts (PR #66 reviews) ----
// Per Will's review (comment 4633722007, revising the earlier 8 mm
// rule down to 5 mm) the posts sit BEHIND the MG996R mounting holes
// and the servo is placed so the very TIP of the driving head hangs
// 5 mm past the baseplate front edge.  The mounting flange (the two
// ears) sits at the body top, so the flange seating plane = the body
// top = the baseplate (porch) front edge.  Pure-X move; gears
// untouched (centre distance + 2:1 ratio live in Z).
driveHeadOverhang      = 5.0
servoWallT             = 6.0                               // post thickness along X
servoWallX             = gearXHi + driveHeadOverhang       // = 59.0 (flange/edge plane)
servoBodyXLo           = servoWallX
servoBodyXHi           = servoBodyXLo + mg996rBodyH
servoWallZLo           = baseT                             // baseplate top in local frame

// Pinion sits at the same X centre as the gear, offset in -Z by the
// centre distance C so the spline sits exactly 10 mm above the base
// top (midline of the MG996R's 20 mm-thick body).
pinionXCentre          = gearXCentre
pinionXLo              = gearXLo
pinionXHi              = gearXHi
pinionY                = yDisp                             // parallel to hinge axis
pinionZ                = zAug - gearCentreC                // = +2.0 mm

// MG996R body extents along Y, and the two square posts that flank it.
// The body protrudes through the open gap between the posts for proper
// alignment (per Will's comment 4624739034 — "green dimension").
servoBodyYLo           = pinionY - mg996rSplineYOffset
servoBodyYHi           = servoBodyYLo + mg996rBodyL
servoGapClear          = 0.5                               // per-side body clearance
servoPostWY            = 14.0                              // post width along Y

// Hole-centre Y offsets from the spline axis — directly annotated on
// the dimensioned drawing as -14.85 mm and +34.65 mm.
mg996rHoleYNear        = -(mg996rSplineYOffset + 7.25 - 2.5)              // -14.85
mg996rHoleYFar         = +(mg996rBodyL - mg996rSplineYOffset + 7.25 - 2.5) // +34.65

// Y spans of the two posts.
nearPostYLo            = servoBodyYLo - servoGapClear - servoPostWY
nearPostYHi            = servoBodyYLo - servoGapClear
farPostYLo             = servoBodyYHi + servoGapClear
farPostYHi             = servoBodyYHi + servoGapClear + servoPostWY

// Arm-clearance slot through the mounting plate — cut so the baseplate
// arms pass cleanly through the plate when it folds flush to 0° tilt.
armSlotYBack           = (baseYFront - armBaseSupportLen) - 2.0   // +73
armSlotClearance       = 0.5                                       // per side along X

// Cantilever-stiffening flange under the tabletop (per Will's PR #66
// review — green-circled location).  A downstand rib in the YZ plane
// at the +X front leg X, tying the cantilevered servo porch down into
// the adjacent front leg.
flangeThk              = 6.0
flangeDepth            = 30.0

// (Linear-actuator base clevis removed — no longer using a linear actuator.)
